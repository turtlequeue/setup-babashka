{
  "name": "setup-babashka",
  "version": "1.4.0",
  "private": false,
  "description": "setup babashka action",
  "main": "src/setup-babashka.ts",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build --license LICENCE",
    "all": "npm run build && npm run format && npm run lint && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/turtlequeue/setup-babashka.git"
  },
  "keywords": [
    "actions",
    "clojure",
    "babashka",
    "github",
    "setup"
  ],
  "author": "nha",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/tool-cache": "^2.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.10",
    "@types/semver": "^7.5.6",
    "@types/uuid": "^9.0.8",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.56.0",
    "eslint-plugin-github": "^4.10.1",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "typescript-formatter": "^7.2.2"
  }
}
